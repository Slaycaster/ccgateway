{
  "name": "ccgateway",
  "version": "0.1.2",
  "description": "Multi-agent orchestration layer built on Claude Code CLI",
  "type": "module",
  "license": "MIT",
  "author": "Denimar Fernandez",
  "repository": {
    "type": "git",
    "url": "https://github.com/Slaycaster/ccgateway"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "orchestration",
    "gateway",
    "cli",
    "clawdbot",
    "openclaw",
    "anthropic"
  ],
  "main": "./dist/config.js",
  "types": "./dist/config.d.ts",
  "exports": {
    ".": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "bin": {
    "ccg": "./dist/cli.js",
    "ccg-dev": "./bin/ccg-dev.sh"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@slack/bolt": "^4.6.0",
    "commander": "^13.1.0",
    "discord.js": "^14.26.2",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
